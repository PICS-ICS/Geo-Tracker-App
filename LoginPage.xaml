<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GeoTrackerApp3.Views.LoginPage"
             Title="Login">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="18" VerticalOptions="Center">
            <Label Text="Welcome back" FontSize="28" HorizontalOptions="Center" />

            <Entry x:Name="EmailEntry"
                   Placeholder="Email"
                   Keyboard="Email"
                   FontSize="16"
                   Text="{Binding Email}" />

            <Entry x:Name="PasswordEntry"
                   IsPassword="True"
                   Placeholder="Password"
                   FontSize="16" />

            <Button Text="Login"
                    x:Name="LoginButton"
                    Clicked="OnLoginClicked"
                    FontSize="16" />

            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
            </HorizontalStackLayout>

            <ActivityIndicator x:Name="BusyIndicator" IsVisible="False" IsRunning="False" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
