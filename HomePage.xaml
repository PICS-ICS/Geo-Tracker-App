<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GeoTrackerApp3.Views.HomePage"
             Title="Home">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Welcome!" FontSize="28" HorizontalOptions="Center" />

        <Label x:Name="UserLabel" FontSize="18" HorizontalOptions="Center" />

        <Label Text="Current Location:" FontSize="20" FontAttributes="Bold" />

        <Label x:Name="LatitudeLabel" Text="Latitude: ..." FontSize="18" />
        <Label x:Name="LongitudeLabel" Text="Longitude: ..." FontSize="18" />

        <Button Text="Refresh Now" Clicked="OnRefreshClicked" />
        <Button Text="Log Out" Clicked="OnLogoutClicked" BackgroundColor="#FF3B30" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>
