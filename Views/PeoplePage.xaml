<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GeoTrackerApp3.Views"
             xmlns:models="clr-namespace:GeoTrackerApp3.Models"
             x:Class="GeoTrackerApp3.Views.PeoplePage"
             x:DataType="vm:PeoplePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Top App Bar -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource CardBackground}"
                StrokeThickness="0"
                Padding="16,16"
                StrokeShape="RoundRectangle 0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="&#x2039;"
                        Clicked="OnBackClicked"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="People"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="Manage your people"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
                <Button Grid.Column="2"
                        Text="Refresh"
                        Clicked="OnRefreshClicked"
                        FontSize="12"
                        TextColor="{StaticResource Primary}"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1"
                        CornerRadius="8"
                        HeightRequest="36"
                        Padding="12,0" />
            </Grid>
        </Border>

        <!-- Controls: Add / Search / Status filter / Count -->
        <VerticalStackLayout Grid.Row="1" Spacing="12" Padding="20,14,20,8">

            <Button Text="&#x002B;  Add Person"
                    Clicked="OnAddPersonClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="48" />

            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    Padding="4,0">
                <SearchBar x:Name="MemberSearchBar"
                           Placeholder="Search name, email, phone or address"
                           TextChanged="OnSearchTextChanged"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{StaticResource Primary}"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource TextMuted}" />
            </Border>

            <!-- Status segmented control -->
            <Border BackgroundColor="{StaticResource Gray100}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="4">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                    <Button x:Name="BtnAll"
                            Grid.Column="0"
                            Text="All"
                            Clicked="OnStatusAllClicked"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="9"
                            HeightRequest="34"
                            Padding="0"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}" />
                    <Button x:Name="BtnActive"
                            Grid.Column="1"
                            Text="Active"
                            Clicked="OnStatusActiveClicked"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="9"
                            HeightRequest="34"
                            Padding="0"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}" />
                    <Button x:Name="BtnInactive"
                            Grid.Column="2"
                            Text="Inactive"
                            Clicked="OnStatusInactiveClicked"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="9"
                            HeightRequest="34"
                            Padding="0"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}" />
                </Grid>
            </Border>

            <Label x:Name="CountLabel"
                   Text=""
                   FontSize="12"
                   TextColor="{StaticResource TextMuted}"
                   Margin="2,0,0,0" />
        </VerticalStackLayout>

        <!-- People List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsLoading}"
                     Command="{Binding RefreshCommand}">
            <CollectionView x:Name="MembersCollection"
                            ItemsSource="{Binding Members}"
                            SelectionMode="None"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReached="OnThresholdReached">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <CollectionView.Header>
                    <BoxView HeightRequest="6" Color="Transparent" />
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Member">
                        <Border BackgroundColor="{StaticResource CardBackground}"
                                StrokeShape="RoundRectangle 14"
                                Stroke="{StaticResource Border}"
                                StrokeThickness="1"
                                Padding="16"
                                Margin="20,0"
                                Shadow="{OnPlatform Default={Shadow Brush=#08000000, Offset='0,2', Radius=6}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMemberTapped" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">

                                <!-- Avatar -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource Secondary}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 24"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding Initials}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource SecondaryDarkText}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="10">

                                    <!-- Name + status badge -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding DisplayType}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="10,4"
                                                VerticalOptions="Start"
                                                HorizontalOptions="End"
                                                BackgroundColor="#F1F5F9">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#DCFCE7" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#64748B">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="TextColor" Value="#16A34A" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </Grid>

                                    <!-- Contact details -->
                                    <VerticalStackLayout Spacing="5">
                                        <HorizontalStackLayout Spacing="8" IsVisible="{Binding HasEmail}">
                                            <Label Text="&#x2709;" FontSize="13" VerticalOptions="Center" />
                                            <Label Text="{Binding Email}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="8" IsVisible="{Binding HasPhone}">
                                            <Label Text="&#x1F4DE;" FontSize="13" VerticalOptions="Center" />
                                            <Label Text="{Binding MobilePhone}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="8" IsVisible="{Binding HasAddress}">
                                            <Label Text="&#x1F4CD;" FontSize="13" VerticalOptions="Start" />
                                            <Label Text="{Binding Address}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <BoxView Color="{StaticResource Border}" HeightRequest="1" />

                                    <!-- Footer: last contacted + age -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0"
                                               Text="{Binding LastContactedText}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextMuted}"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AgeText}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32,48" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="&#x1F465;"
                               FontSize="34"
                               HorizontalOptions="Center" />
                        <Label Text="No people found"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" />
                        <Label Text="Try adjusting your search or status filter."
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <VerticalStackLayout Padding="0,12,0,24">
                        <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                           IsVisible="{Binding IsLoadingMore}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="28" />
                    </VerticalStackLayout>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
