<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GeoTrackerApp3.Views"
             xmlns:models="clr-namespace:GeoTrackerApp3.Models"
             x:Class="GeoTrackerApp3.Views.EditPersonPage"
             x:DataType="vm:EditPersonPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top App Bar -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource CardBackground}"
                StrokeThickness="0"
                Padding="16,16"
                StrokeShape="RoundRectangle 0">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0"
                        Text="&#x2039;"
                        Clicked="OnBackClicked"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="HeaderTitleLabel"
                           Text="Edit Person"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    <Label x:Name="HeaderSubtitleLabel"
                           Text="Update person details"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollView Grid.Row="1" Padding="20,16">
            <VerticalStackLayout Spacing="16">

                <!-- Identity Card -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Identity"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <!-- Entity Type -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Entity Type *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker x:Name="EntityTypePicker"
                                        Title="Select entity type"
                                        ItemDisplayBinding="{Binding Text}"
                                        SelectedIndexChanged="OnEntityTypeChanged"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Title (person only) -->
                        <VerticalStackLayout x:Name="TitleSection" Spacing="6">
                            <Label Text="Title" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker x:Name="TitlePicker"
                                        Title="Select title"
                                        ItemDisplayBinding="{Binding Text}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- First name -->
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="FirstNameLabel" Text="First Name *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="FirstNameEntry"
                                       Placeholder="First name"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Last name (person only) -->
                        <VerticalStackLayout x:Name="LastNameSection" Spacing="6">
                            <Label Text="Last Name *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="LastNameEntry"
                                       Placeholder="Last name"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Gender (person only) -->
                        <VerticalStackLayout x:Name="GenderSection" Spacing="6">
                            <Label Text="Gender *" Style="{StaticResource FieldLabel}" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button x:Name="MaleButton"
                                        Grid.Column="0"
                                        Text="Male"
                                        Clicked="OnMaleClicked"
                                        FontSize="14"
                                        CornerRadius="10"
                                        HeightRequest="44"
                                        BorderWidth="1" />
                                <Button x:Name="FemaleButton"
                                        Grid.Column="1"
                                        Text="Female"
                                        Clicked="OnFemaleClicked"
                                        FontSize="14"
                                        CornerRadius="10"
                                        HeightRequest="44"
                                        BorderWidth="1" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Date of birth (person only) -->
                        <VerticalStackLayout x:Name="DobSection" Spacing="6">
                            <Label Text="Date of Birth" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <DatePicker x:Name="DobPicker"
                                            Format="dd MMM yyyy"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Contact Card -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Contact"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="EmailEntry"
                                       Placeholder="name@example.com"
                                       Keyboard="Email"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Phone -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Phone Number *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="MobileEntry"
                                       Placeholder="Mobile number"
                                       Keyboard="Telephone"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Home contact (person only) -->
                        <VerticalStackLayout x:Name="HomeContactSection" Spacing="6">
                            <Label Text="Home Contact" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="HomeContactEntry"
                                       Placeholder="Home number"
                                       Keyboard="Telephone"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Address with autocomplete suggestions -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Address *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="AddressEntry"
                                       Placeholder="Street, city, country"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Classification Card -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Classification"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <!-- Leader autocomplete -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Leader Name *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="LeaderEntry"
                                       Placeholder="Type at least 3 letters to search"
                                       TextChanged="OnLeaderTextChanged"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                            <!-- Suggestions dropdown -->
                            <Border x:Name="LeaderSuggestionsBorder"
                                    BackgroundColor="{StaticResource CardBackground}"
                                    Stroke="{StaticResource Border}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    IsVisible="False"
                                    Padding="0">
                                <CollectionView x:Name="LeaderSuggestions"
                                                HeightRequest="180"
                                                SelectionMode="Single"
                                                SelectionChanged="OnLeaderSelected">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:LeaderItem">
                                            <Grid Padding="14,12" BackgroundColor="{StaticResource CardBackground}">
                                                <Label Text="{Binding Display}"
                                                       FontSize="14"
                                                       TextColor="{StaticResource TextPrimary}" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Person Type -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Person Type *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker x:Name="MemberTypePicker"
                                        Title="Select person type"
                                        ItemDisplayBinding="{Binding Text}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Account Card -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Account &amp; Status"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <!-- Username -->
                        <VerticalStackLayout x:Name="UserNameSection" Spacing="6">
                            <Label x:Name="UserNameLabel" Text="Username" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="UserNameEntry"
                                       Placeholder="Username"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- External password (person only) -->
                        <VerticalStackLayout x:Name="ExternalPasswordSection" Spacing="6">
                            <Label Text="External Password" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="ExternalPasswordEntry"
                                       Placeholder="External password"
                                       IsPassword="True"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Role (add-user only) -->
                        <VerticalStackLayout x:Name="RoleSection" Spacing="6" IsVisible="False">
                            <Label Text="Role *" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker x:Name="RolePicker"
                                        Title="Select role"
                                        ItemDisplayBinding="{Binding Text}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- ID / Passport (person only) -->
                        <VerticalStackLayout x:Name="RsaIdSection" Spacing="6">
                            <Label Text="ID / Passport No" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="RsaIdEntry"
                                       Placeholder="ID or passport number"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Employee code -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Employee Code" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="EmpCodeEntry"
                                       Placeholder="Employee code"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- External reference -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="External Reference" Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry x:Name="ExternalRefEntry"
                                       Placeholder="External reference"
                                       Style="{StaticResource FieldEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Status switch -->
                        <Grid ColumnDefinitions="*,Auto" Padding="2,4">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label x:Name="StatusLabel"
                                       Text="Person Status"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label x:Name="StatusHintLabel"
                                       Text="Active"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Switch x:Name="StatusSwitch"
                                    Grid.Column="1"
                                    IsToggled="True"
                                    Toggled="OnStatusToggled"
                                    OnColor="{StaticResource Success}"
                                    VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="4" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom action bar -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource CardBackground}"
                StrokeShape="RoundRectangle 0"
                Stroke="{StaticResource Border}"
                StrokeThickness="0.5"
                Padding="20,12"
                Shadow="{OnPlatform Default={Shadow Brush=#10000000, Offset='0,-2', Radius=8}}">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Text="Cancel"
                        Clicked="OnCancelClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        BorderColor="{StaticResource Border}"
                        BorderWidth="1"
                        CornerRadius="12"
                        FontSize="15"
                        HeightRequest="50" />
                <Button x:Name="SaveButton"
                        Grid.Column="1"
                        Text="Save"
                        Clicked="OnSaveClicked"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="12"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="50" />
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              BackgroundColor="#80000000"
              IsVisible="False">
            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 14"
                    Padding="28"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="12">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" />
                    <Label x:Name="LoadingLabel"
                           Text="Loading..."
                           FontSize="13"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
